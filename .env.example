# Django signing key for sessions/CSRF.
DJANGO_SECRET_KEY=
# 0 in production, 1 only for local debugging.
DJANGO_DEBUG=
# Comma-separated hostnames, e.g. localhost,127.0.0.1.
DJANGO_ALLOWED_HOSTS=
# Comma-separated origins with scheme, e.g. https://localhost:8000.
DJANGO_CSRF_TRUSTED_ORIGINS=
# 1 to force HTTPS redirect, 0 for local HTTP.
DJANGO_SECURE_SSL_REDIRECT=
# PostgreSQL database name.
POSTGRES_DB=
# PostgreSQL username.
POSTGRES_USER=
# PostgreSQL password.
POSTGRES_PASSWORD=
# PostgreSQL host.
POSTGRES_HOST=
# PostgreSQL port.
POSTGRES_PORT=
# OpenAI API key for receipt analysis.
OPENAI_API_KEY=
# OpenAI model for receipt analysis.
OPENAI_MODEL=
# Google OAuth2 Client ID.
GOOGLE_OAUTH_CLIENT_ID=
# Google OAuth2 Client Secret.
GOOGLE_OAUTH_CLIENT_SECRET=
# Stripe secret key.
STRIPE_SECRET_KEY=
# Stripe Price ID for 49 kr/mån subscription.
STRIPE_PRICE_MONTHLY_ID=
# Stripe Price ID for 499 kr/år subscription.
STRIPE_PRICE_YEARLY_ID=
# Cloudinary URL (alternativ till separata CLOUDINARY_* variabler).
CLOUDINARY_URL=
# Cloudinary cloud name.
CLOUDINARY_CLOUD_NAME=
# Cloudinary API key.
CLOUDINARY_API_KEY=
# Cloudinary API secret.
CLOUDINARY_API_SECRET=
# Number of receipts allowed before subscription is required.
FREEMIUM_RECEIPT_LIMIT=
# Kontaktväg för integritetsfrågor som visas på integritetspolicyn.
PRIVACY_CONTACT=
# Transaktionsmail via SMTP.
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.test
EMAIL_USE_TLS=0
